rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Menu images: public read; only signed-in staff can upload (<=5MB images).
    match /menu/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
